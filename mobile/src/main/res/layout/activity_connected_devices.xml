<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <!-- ===== Toolbar ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="36dp"
        android:paddingBottom="16dp"
        android:background="@color/white">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_arrow_small_left"
            app:tint="@color/text_dark"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connected Devices"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:fontFamily="@font/inter"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Your Devices Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Devices"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:fontFamily="@font/inter" />

            <!-- Device 1: Phone -->
            <LinearLayout
                android:id="@+id/devicePhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_device_card"
                android:padding="16dp"
                android:layout_marginTop="16dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_tablet_android"
                    app:tint="@color/text_secondary"
                    android:importantForAccessibility="no" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:id="@+id/tvPhoneName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Poco M7 Pro 5G"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/inter" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp">

                        <TextView
                            android:id="@+id/tvPhoneStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Connected"
                            android:textSize="13sp"
                            android:textColor="#6EDB34"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" · "
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:id="@+id/tvPhoneBattery"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="90% battery"
                            android:textSize="13sp"
                            android:textColor="#6EDB34"
                            android:fontFamily="@font/inter" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPhoneSync"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last sync: 2 min ago"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:fontFamily="@font/inter"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Device 2: Watch -->

            <!-- Add Devices Button -->
            <LinearLayout
                android:id="@+id/deviceWatch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_device_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_fitness_watch"
                    app:tint="@color/text_secondary" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvWatchName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter"
                        android:text="Samsung Watch 7"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvWatchStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="Connected"
                            android:textColor="#6EDB34"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text=" · "
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvWatchBattery"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="62% battery"
                            android:textColor="#6EDB34"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvWatchSync"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/inter"
                        android:text="Last sync: 5 min ago"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/btnAddDevice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add devices"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#6EDB34"
                android:fontFamily="@font/inter"
                android:gravity="center"
                android:background="@drawable/bg_add_device_button"
                android:padding="16dp"
                android:layout_marginTop="20dp"
                android:clickable="true"
                android:focusable="true" />

            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Supported Devices Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="40dp"
                android:paddingTop="16dp">

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_light"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Supported Devices"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:fontFamily="@font/inter" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Android Devices\n• Samsung watch 7 and Higher Versions"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="@font/inter"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>

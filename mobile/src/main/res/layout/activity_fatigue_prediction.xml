<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- ===== No Active Session Overlay ===== -->
    <LinearLayout
        android:id="@+id/layoutNoSession"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_activity"
            android:contentDescription="No session"
            app:tint="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Active Session"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:fontFamily="@font/inter"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start an activity session to see real-time fatigue predictions."
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartSession"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start Session"
            android:textAllCaps="false"
            app:cornerRadius="8dp"
            android:backgroundTint="@color/green_primary" />

    </LinearLayout>

    <!-- ===== Scrollable Content ===== -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ===== Page Header ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fatigue Analysis"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/green_primary"
                android:fontFamily="@font/inter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI-Powered Prediction"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/inter"
                android:layout_marginBottom="16dp" />

            <!-- ===== Current Fatigue Level Card ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <!-- Left: text info -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Current Fatigue Level"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Status:"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="@font/inter"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:id="@+id/tvFatigueStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Waiting for data..."
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#999999"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Classification:"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="@font/inter"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:id="@+id/tvFatigueClassification"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="14sp"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HR:"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="@font/inter"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:id="@+id/tvHrValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Establishing baseline..."
                            android:textSize="14sp"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HRV:"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="@font/inter"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:id="@+id/tvHrvValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Establishing baseline..."
                            android:textSize="14sp"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter" />

                    </LinearLayout>

                    <!-- Right: circular gauge -->
                    <com.example.fitguard.ui.chart.RecoveryGaugeView
                        android:id="@+id/gaugeFatigue"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Scaler Comparison Card ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardScalerComparison"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Scaler Comparison"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/inter" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Same model, different normalization"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/inter"
                        android:layout_marginBottom="12dp" />

                    <!-- Column headers -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Global"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:gravity="center"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Ext. Trained"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:gravity="center"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="On-Device"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:gravity="center"
                            android:fontFamily="@font/inter" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/border_light" />

                    <!-- Level row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="8dp"
                        android:paddingBottom="4dp">

                        <TextView
                            android:id="@+id/tvCompGlobalLevel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="--"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:id="@+id/tvCompExternalLevel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="--"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:id="@+id/tvCompOnDeviceLevel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="--"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:fontFamily="@font/inter" />

                    </LinearLayout>

                    <!-- P(High) row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="4dp">

                        <TextView
                            android:id="@+id/tvCompGlobalPHigh"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="P(H): --"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:gravity="center"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:id="@+id/tvCompExternalPHigh"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="P(H): --"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:gravity="center"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:id="@+id/tvCompOnDevicePHigh"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="P(H): --"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:gravity="center"
                            android:fontFamily="@font/inter" />

                    </LinearLayout>

                    <!-- Status row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvCompGlobalStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Loading..."
                            android:textSize="10sp"
                            android:textColor="@color/text_secondary"
                            android:gravity="center"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:id="@+id/tvCompExternalStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Loading..."
                            android:textSize="10sp"
                            android:textColor="@color/text_secondary"
                            android:gravity="center"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:id="@+id/tvCompOnDeviceStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Loading..."
                            android:textSize="10sp"
                            android:textColor="@color/text_secondary"
                            android:gravity="center"
                            android:fontFamily="@font/inter" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Session Fatigue Trend Card ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSessionTrend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Session Fatigue Trend"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/inter" />

                    <TextView
                        android:id="@+id/tvTrendSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dashed line shows 5-min prediction"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/inter"
                        android:layout_marginTop="2dp" />

                    <com.example.fitguard.ui.chart.SessionFatigueTrendChartView
                        android:id="@+id/chartSessionTrend"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Recovery Plan Card ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recovery Plan"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/inter"
                        android:layout_marginBottom="8dp" />

                    <!-- Item 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Get 8+ hours of sleep tonight"
                            android:textSize="13sp"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="High Priority"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/red_stop"
                            android:fontFamily="@font/inter" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/border_light" />

                    <!-- Item 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Drink 2-3L of water today"
                            android:textSize="13sp"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="High Priority"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/red_stop"
                            android:fontFamily="@font/inter" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/border_light" />

                    <!-- Item 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Light stretching or yoga"
                            android:textSize="13sp"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Medium Priority"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#FF8C00"
                            android:fontFamily="@font/inter" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/border_light" />

                    <!-- Item 4 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Focus on protein-rich meals"
                            android:textSize="13sp"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Medium Priority"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#FF8C00"
                            android:fontFamily="@font/inter" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Contributing Factors Card ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contributing Factors"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/inter"
                        android:layout_marginBottom="10dp" />

                    <!-- Row 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Red dot + Poor sleep quality -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:background="@drawable/bg_dot"
                                android:backgroundTint="@color/red_stop"
                                android:layout_marginEnd="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Poor sleep quality"
                                android:textSize="13sp"
                                android:textColor="@color/text_dark"
                                android:fontFamily="@font/inter" />

                        </LinearLayout>

                        <!-- Orange dot + Poor Hydration -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:background="@drawable/bg_dot"
                                android:backgroundTint="#FF8C00"
                                android:layout_marginEnd="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Poor Hydration"
                                android:textSize="13sp"
                                android:textColor="@color/text_dark"
                                android:fontFamily="@font/inter" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Row 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <!-- Red dot + High Stress levels -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:background="@drawable/bg_dot"
                                android:backgroundTint="@color/red_stop"
                                android:layout_marginEnd="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="High Stress levels"
                                android:textSize="13sp"
                                android:textColor="@color/text_dark"
                                android:fontFamily="@font/inter" />

                        </LinearLayout>

                        <!-- Orange dot + Poor Hydration -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:background="@drawable/bg_dot"
                                android:backgroundTint="#FF8C00"
                                android:layout_marginEnd="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Poor Hydration"
                                android:textSize="13sp"
                                android:textColor="@color/text_dark"
                                android:fontFamily="@font/inter" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ===== Bottom Navigation ===== -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:elevation="8dp"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:labelVisibilityMode="unlabeled"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

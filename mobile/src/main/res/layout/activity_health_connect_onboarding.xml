<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="48dp">

        <!-- Icon -->
        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_bed"
            app:tint="#1565C0"
            android:contentDescription="Health Connect" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connect to Health Connect"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:fontFamily="@font/inter"
            android:layout_marginTop="20dp"
            android:gravity="center" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FitGuard will read the following data from Samsung Health via Health Connect:"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/inter"
            android:layout_marginTop="12dp"
            android:gravity="center" />

        <!-- Data types card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#F5F5F5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Sleep row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_moon_stars"
                        app:tint="#1565C0"
                        android:contentDescription="Sleep" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sleep"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sleep sessions and stages"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="@font/inter" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0" />

                <!-- Stress / HRV row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_heart_brain"
                        app:tint="#1565C0"
                        android:contentDescription="Stress" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Stress (Heart Rate Variability)"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HRV readings for stress estimation"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="@font/inter" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Read-only note -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FitGuard only reads this data. It does not write or modify any health data."
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/inter"
            android:layout_marginTop="16dp"
            android:gravity="center" />

    </LinearLayout>

    <!-- Bottom buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAllow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Allow access"
        android:textSize="16sp"
        android:fontFamily="@font/inter"
        app:backgroundTint="#1565C0"
        android:layout_marginBottom="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNotNow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Not now"
        android:textSize="16sp"
        android:fontFamily="@font/inter"
        app:backgroundTint="@android:color/transparent"
        android:textColor="@color/text_secondary"
        style="@style/Widget.MaterialComponents.Button.TextButton" />

</LinearLayout>

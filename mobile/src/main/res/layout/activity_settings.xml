<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- ===== Toolbar ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="36dp"
        android:paddingBottom="16dp"
        android:background="@color/white">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_arrow_small_left"
            app:tint="@color/text_dark"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:fontFamily="@font/inter"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== Notifications Section ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notifications"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:fontFamily="@font/inter"
                android:background="@drawable/bg_section_header"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp" />

            <!-- Activity Reminders -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Activity Reminders"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/inter" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Daily reminders to stay active"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/inter"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchActivity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:trackTint="@color/text_hint"
                    app:thumbTint="@color/white" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_light"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp" />

            <!-- Goal Achievements -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Goal Achievements"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/inter" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Celebrate when you hit your goals"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/inter"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchGoals"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:trackTint="@color/text_hint"
                    app:thumbTint="@color/white" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_light"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp" />

            <!-- Recovery Alerts -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recovery Alerts"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/inter" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Get notified about recovery status"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/inter"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchRecovery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:trackTint="@color/text_hint"
                    app:thumbTint="@color/white" />

            </LinearLayout>

            <!-- ===== Preference Section ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Preference"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:fontFamily="@font/inter"
                android:background="@drawable/bg_section_header"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp" />

            <!-- Heart Rate -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Heart Rate"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:fontFamily="@font/inter" />

                <RadioGroup
                    android:id="@+id/rgHeartRate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp">

                    <RadioButton
                        android:id="@+id/rbHrManual"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Manual"
                        android:textSize="14sp"
                        android:textColor="#6EDB34"
                        android:fontFamily="@font/inter"
                        android:buttonTint="#6EDB34"
                        android:checked="true"
                        android:paddingStart="8dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp" />

                    <RadioButton
                        android:id="@+id/rbHr10Min"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Every 10 minutes"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/inter"
                        android:buttonTint="#6EDB34"
                        android:paddingStart="8dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp" />

                    <RadioButton
                        android:id="@+id/rbHrContinuous"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Continuous"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/inter"
                        android:buttonTint="#6EDB34"
                        android:paddingStart="8dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp" />

                </RadioGroup>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_light"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="8dp" />

            <!-- Blood Oxygen (SpO2) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blood Oxygen (SpO2)"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:fontFamily="@font/inter" />

                <RadioGroup
                    android:id="@+id/rgSpO2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp">

                    <RadioButton
                        android:id="@+id/rbSpO2Manual"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Manual"
                        android:textSize="14sp"
                        android:textColor="#6EDB34"
                        android:fontFamily="@font/inter"
                        android:buttonTint="#6EDB34"
                        android:checked="true"
                        android:paddingStart="8dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp" />

                    <RadioButton
                        android:id="@+id/rbSpO210Min"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Every 10 minutes"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/inter"
                        android:buttonTint="#6EDB34"
                        android:paddingStart="8dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp" />

                </RadioGroup>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_light"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="8dp" />

            <!-- Skin Temperature -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Skin Temperature"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:fontFamily="@font/inter" />

                <RadioGroup
                    android:id="@+id/rgSkinTemp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp">

                    <RadioButton
                        android:id="@+id/rbSkinTempManual"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Manual"
                        android:textSize="14sp"
                        android:textColor="#6EDB34"
                        android:fontFamily="@font/inter"
                        android:buttonTint="#6EDB34"
                        android:checked="true"
                        android:paddingStart="8dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp" />

                    <RadioButton
                        android:id="@+id/rbSkinTemp10Min"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Every 10 minutes"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/inter"
                        android:buttonTint="#6EDB34"
                        android:paddingStart="8dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp" />

                </RadioGroup>

            </LinearLayout>

            <!-- ===== Data Management Section ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Data Management"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:fontFamily="@font/inter"
                android:background="@drawable/bg_section_header"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp" />

            <!-- Export Data -->
            <LinearLayout
                android:id="@+id/menuExportData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Export Data"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/inter" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Download your activity history"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/inter"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_angle_small_right"
                    app:tint="@color/text_hint"
                    android:importantForAccessibility="no" />

            </LinearLayout>

            <!-- Delete Account -->
            <LinearLayout
                android:id="@+id/menuDeleteAccount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="24dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delete Account"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#FF0000"
                        android:fontFamily="@font/inter" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Permanently delete Your Data"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/inter"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_angle_small_right"
                    app:tint="@color/text_hint"
                    android:importantForAccessibility="no" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>

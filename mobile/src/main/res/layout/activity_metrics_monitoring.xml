<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- ===== Header ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="36dp"
        android:paddingBottom="16dp"
        android:background="@color/white">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_arrow_small_left"
            app:tint="@color/text_dark"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Metrics Monitoring"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:fontFamily="@font/inter"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <!-- ===== Scrollable Content ===== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ===== Heart Rate Card ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Heart Rate"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchHeartRate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:trackTint="#6EDB34"
                            app:thumbTint="@color/white"
                            android:checked="true"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/tvHeartRateValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="72 bpm"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter" />

                    </LinearLayout>

                    <com.example.fitguard.ui.chart.HeartRateChartView
                        android:id="@+id/chartHeartRate"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMeasureHeartRate"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:text="Measure"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/inter"
                        app:cornerRadius="12dp"
                        app:backgroundTint="#6EDB34"
                        android:textColor="@color/white" />

                    <!-- Stats Row -->
                    <LinearLayout
                        android:id="@+id/hrStatsRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_stat_box"
                            android:padding="10dp"
                            android:layout_marginEnd="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Avg"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary"
                                android:fontFamily="@font/inter" />

                            <TextView
                                android:id="@+id/tvHrAvg"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="78"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"
                                android:fontFamily="@font/inter" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_stat_box"
                            android:padding="10dp"
                            android:layout_marginStart="3dp"
                            android:layout_marginEnd="3dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Min"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary"
                                android:fontFamily="@font/inter" />

                            <TextView
                                android:id="@+id/tvHrMin"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="63"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"
                                android:fontFamily="@font/inter" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_stat_box"
                            android:padding="10dp"
                            android:layout_marginStart="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Max"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary"
                                android:fontFamily="@font/inter" />

                            <TextView
                                android:id="@+id/tvHrMax"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="102"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"
                                android:fontFamily="@font/inter" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Skin Temperature Card ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Skin Temperature"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchSkinTemp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:trackTint="#6EDB34"
                            app:thumbTint="@color/white"
                            android:checked="true"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/tvSkinTempValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-- °C"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter" />

                    </LinearLayout>

                    <com.example.fitguard.ui.chart.SkinTemperatureChartView
                        android:id="@+id/chartSkinTemp"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMeasureSkinTemp"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:text="Measure"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/inter"
                        app:cornerRadius="12dp"
                        app:backgroundTint="#6EDB34"
                        android:textColor="@color/white" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Blood Oxygen Card ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Blood Oxygen"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchSpO2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:trackTint="#6EDB34"
                            app:thumbTint="@color/white"
                            android:checked="true"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/tvSpO2Value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="85% SpO2"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter" />

                    </LinearLayout>

                    <com.example.fitguard.ui.chart.BloodOxygenChartView
                        android:id="@+id/chartBloodOxygen"
                        android:layout_width="match_parent"
                        android:layout_height="260dp"
                        android:layout_marginTop="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMeasureSpO2"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:text="Measure"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/inter"
                        app:cornerRadius="12dp"
                        app:backgroundTint="#6EDB34"
                        android:textColor="@color/white" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light_gray">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="36dp"
        android:paddingBottom="16dp"
        android:background="@color/white">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_arrow_small_left"
            app:tint="@color/text_dark"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Samsung Health"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:fontFamily="@font/inter"
            android:layout_marginStart="12dp" />

        <TextView
            android:id="@+id/btnSync"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sync"
            android:textSize="14sp"
            android:textColor="#1565C0"
            android:fontFamily="@font/inter"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="4dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Status banner -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:textSize="13sp"
        android:textColor="@color/white"
        android:background="#1565C0"
        android:gravity="center"
        android:fontFamily="@font/inter"
        android:visibility="gone" />

    <!-- Setup card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSetup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="1dp"
        app:strokeColor="#1565C0"
        app:cardBackgroundColor="#EFF6FF"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tvSetupTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Health Connect"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1565C0"
                android:fontFamily="@font/inter"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvSetupMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:fontFamily="@font/inter"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGrantPermissions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connect Samsung Health"
                android:textSize="14sp"
                android:fontFamily="@font/inter"
                app:backgroundTint="#1565C0"
                android:visibility="gone" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Scrollable metrics -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollMetrics"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ===== Activity Today ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Activity Today"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/inter"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <include layout="@layout/item_metric_tile" android:id="@+id/tileSteps"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="4dp" />
                <include layout="@layout/item_metric_tile" android:id="@+id/tileDistance"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="4dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <include layout="@layout/item_metric_tile" android:id="@+id/tileCalories"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="4dp" />
                <include layout="@layout/item_metric_tile" android:id="@+id/tileFloors"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- ===== Vitals ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vitals"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/inter"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <include layout="@layout/item_metric_tile" android:id="@+id/tileHeartRate"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="4dp" />
                <include layout="@layout/item_metric_tile" android:id="@+id/tileRestingHR"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="4dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <include layout="@layout/item_metric_tile" android:id="@+id/tileSpO2"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="4dp" />
                <include layout="@layout/item_metric_tile" android:id="@+id/tileRespiratoryRate"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="4dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <include layout="@layout/item_metric_tile" android:id="@+id/tileBodyTemp"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="4dp" />
                <include layout="@layout/item_metric_tile" android:id="@+id/tileBloodPressure"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- ===== Blood Metrics ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blood Metrics"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/inter"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <include layout="@layout/item_metric_tile" android:id="@+id/tileBloodGlucose"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="4dp" />
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- ===== Body Composition ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Body Composition"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/inter"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <include layout="@layout/item_metric_tile" android:id="@+id/tileWeight"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="4dp" />
                <include layout="@layout/item_metric_tile" android:id="@+id/tileHeight"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="4dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <include layout="@layout/item_metric_tile" android:id="@+id/tileBmi"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="4dp" />
                <include layout="@layout/item_metric_tile" android:id="@+id/tileBodyFat"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="4dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <include layout="@layout/item_metric_tile" android:id="@+id/tileLeanMass"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="4dp" />
                <include layout="@layout/item_metric_tile" android:id="@+id/tileBmr"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="4dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <include layout="@layout/item_metric_tile" android:id="@+id/tileVo2Max"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="4dp" />
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- Manage access link -->
            <TextView
                android:id="@+id/btnManageAccess"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manage Health Connect access"
                android:textSize="12sp"
                android:textColor="#1565C0"
                android:fontFamily="@font/inter"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>

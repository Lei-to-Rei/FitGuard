<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet permission for Firebase -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Permission to check network state -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Background processing for activity data sync -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FitGuard">

        <!-- ========================================== -->
        <!-- SPLASH ACTIVITY - NEW LAUNCHER (Entry Point) -->
        <!-- ========================================== -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.FitGuard.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ========================================== -->
        <!-- ONBOARDING ACTIVITY -->
        <!-- ========================================== -->
        <activity
            android:name=".onboarding.OnboardingActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ========================================== -->
        <!-- PROFILE SETUP ACTIVITY -->
        <!-- ========================================== -->
        <activity
            android:name=".onboarding.ProfileSetupActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ========================================== -->
        <!-- LOGIN ACTIVITY -->
        <!-- ========================================== -->
        <activity
            android:name=".auth.LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========================================== -->
        <!-- REGISTER ACTIVITY -->
        <!-- ========================================== -->
        <activity
            android:name=".auth.RegisterActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========================================== -->
        <!-- MAIN ACTIVITY (PPG Data Display) -->
        <!-- Changed: Remove launcher intent, add exported=false -->
        <!-- ========================================== -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ========================================== -->
        <!-- METRICS MONITORING -->
        <!-- ========================================== -->
        <activity
            android:name=".features.metrics.MetricsMonitoringActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========================================== -->
        <!-- FATIGUE PREDICTION -->
        <!-- ========================================== -->
        <activity
            android:name=".features.fatigue.FatiguePredictionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========================================== -->
        <!-- NUTRITION TRACKING -->
        <!-- ========================================== -->
        <activity
            android:name=".features.nutrition.NutritionTrackingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========================================== -->
        <!-- RECOVERY RECOMMENDATIONS -->
        <!-- ========================================== -->
        <activity
            android:name=".features.recommendations.RecoveryRecommendationsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========================================== -->
        <!-- RECOVERY PROGRESS -->
        <!-- ========================================== -->
        <activity
            android:name=".features.recovery.RecoveryProgressActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========================================== -->
        <!-- SLEEP AND STRESS -->
        <!-- ========================================== -->
        <activity
            android:name=".features.sleep.SleepStressActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========================================== -->
        <!-- ACTIVITY TRACKING -->
        <!-- ========================================== -->
        <activity
            android:name=".features.activitytracking.ActivityTrackingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========================================== -->
        <!-- PROFILE: USER HOME -->
        <!-- ========================================== -->
        <activity
            android:name=".features.profile.UserHomeActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ========================================== -->
        <!-- PROFILE: SETTINGS -->
        <!-- ========================================== -->
        <activity
            android:name=".features.profile.SettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ========================================== -->
        <!-- PROFILE: CONNECTED DEVICES -->
        <!-- ========================================== -->
        <activity
            android:name=".features.profile.ConnectedDevicesActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ========================================== -->
        <!-- PROFILE: PERSONAL BASELINE -->
        <!-- ========================================== -->
        <activity
            android:name=".features.profile.PersonalBaselineActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========================================== -->
        <!-- PROFILE: SUPPORT & FEEDBACK -->
        <!-- ========================================== -->
        <activity
            android:name=".features.profile.SupportFeedbackActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Wearable Data Listener Service -->
        <service
            android:name=".services.WearableDataListenerService"
            android:exported="true"
            android:stopWithTask="false">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data android:scheme="wear" android:host="*" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*"
                    android:pathPrefix="/fitguard/activity" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*"
                    android:pathPrefix="/fitguard/device" />
            </intent-filter>
        </service>

        <!-- Mobile Foreground Service for activity data sync -->
        <service
            android:name=".services.SessionForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>
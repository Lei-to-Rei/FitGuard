<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet permission for Firebase -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Permission to check network state -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- Location tracking for activity routes -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Background processing for activity data sync -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Health Connect permissions -->
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE_VARIABILITY" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_TOTAL_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_DISTANCE" />
    <uses-permission android:name="android.permission.health.READ_FLOORS_CLIMBED" />
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_RESTING_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_OXYGEN_SATURATION" />
    <uses-permission android:name="android.permission.health.READ_RESPIRATORY_RATE" />
    <uses-permission android:name="android.permission.health.READ_BODY_TEMPERATURE" />
    <uses-permission android:name="android.permission.health.READ_BLOOD_PRESSURE" />
    <uses-permission android:name="android.permission.health.READ_BLOOD_GLUCOSE" />
    <uses-permission android:name="android.permission.health.READ_WEIGHT" />
    <uses-permission android:name="android.permission.health.READ_HEIGHT" />
    <uses-permission android:name="android.permission.health.READ_BODY_FAT" />
    <uses-permission android:name="android.permission.health.READ_LEAN_BODY_MASS" />
    <uses-permission android:name="android.permission.health.READ_BASAL_METABOLIC_RATE" />
    <uses-permission android:name="android.permission.health.READ_VO2_MAX" />

    <queries>
        <package android:name="com.google.android.apps.healthdata" />
        <intent>
            <action android:name="androidx.health.ACTION_HEALTH_CONNECT_SETTINGS" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FitGuard">

        <!-- ========================================== -->
        <!-- SPLASH ACTIVITY - NEW LAUNCHER (Entry Point) -->
        <!-- ========================================== -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.FitGuard.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ========================================== -->
        <!-- ONBOARDING ACTIVITY -->
        <!-- ========================================== -->
        <activity
            android:name=".onboarding.OnboardingActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ========================================== -->
        <!-- PROFILE SETUP ACTIVITY -->
        <!-- ========================================== -->
        <activity
            android:name=".onboarding.ProfileSetupActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ========================================== -->
        <!-- LOGIN ACTIVITY -->
        <!-- ========================================== -->
        <activity
            android:name=".auth.LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========================================== -->
        <!-- REGISTER ACTIVITY -->
        <!-- ========================================== -->
        <activity
            android:name=".auth.RegisterActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========================================== -->
        <!-- MAIN ACTIVITY (PPG Data Display) -->
        <!-- Changed: Remove launcher intent, add exported=false -->
        <!-- ========================================== -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ========================================== -->
        <!-- METRICS MONITORING -->
        <!-- ========================================== -->
        <activity
            android:name=".features.metrics.MetricsMonitoringActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========================================== -->
        <!-- FATIGUE PREDICTION -->
        <!-- ========================================== -->
        <activity
            android:name=".features.fatigue.FatiguePredictionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========================================== -->
        <!-- NUTRITION TRACKING -->
        <!-- ========================================== -->
        <activity
            android:name=".features.nutrition.NutritionTrackingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========================================== -->
        <!-- RECOVERY RECOMMENDATIONS -->
        <!-- ========================================== -->
        <activity
            android:name=".features.recommendations.RecoveryRecommendationsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========================================== -->
        <!-- SLEEP AND STRESS -->
        <!-- ========================================== -->
        <activity
            android:name=".features.sleep.SleepStressActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize">
            <!-- Pre-Android 14: permission rationale -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
            <meta-data
                android:name="health_permissions_privacy_policy_url"
                android:value="https://fitguard.app/privacy" />
        </activity>

        <!-- Android 14+: required alias for Health Connect to show permission usage screen -->
        <activity-alias
            android:name=".features.sleep.ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".features.sleep.SleepStressActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!-- ========================================== -->
        <!-- SAMSUNG HEALTH DASHBOARD -->
        <!-- ========================================== -->
        <activity
            android:name=".features.health.SamsungHealthActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ========================================== -->
        <!-- HEALTH CONNECT ONBOARDING (pre-Android 14) -->
        <!-- ========================================== -->
        <activity
            android:name=".features.sleep.HealthConnectOnboardingActivity"
            android:exported="true"
            android:permission="com.google.android.apps.healthdata.permission.START_ONBOARDING"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_ONBOARDING" />
            </intent-filter>
        </activity>

        <!-- Health Connect Onboarding alias (Android 14+) -->
        <activity-alias
            android:name=".features.sleep.UAndAboveHealthConnectOnboardingActivity"
            android:exported="true"
            android:targetActivity=".features.sleep.HealthConnectOnboardingActivity"
            android:permission="android.permission.health.START_ONBOARDING">
            <intent-filter>
                <action android:name="android.health.connect.action.SHOW_ONBOARDING" />
            </intent-filter>
        </activity-alias>

        <!-- ========================================== -->
        <!-- ACTIVITY TRACKING -->
        <!-- ========================================== -->
        <activity
            android:name=".features.activitytracking.ActivityTrackingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========================================== -->
        <!-- ACTIVITY HISTORY -->
        <!-- ========================================== -->
        <activity
            android:name=".features.activitytracking.ActivityHistoryActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ========================================== -->
        <!-- ACTIVITY DETAIL -->
        <!-- ========================================== -->
        <activity
            android:name=".features.activitytracking.ActivityDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ========================================== -->
        <!-- PROFILE: USER HOME -->
        <!-- ========================================== -->
        <activity
            android:name=".features.profile.UserHomeActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ========================================== -->
        <!-- PROFILE: SETTINGS -->
        <!-- ========================================== -->
        <activity
            android:name=".features.profile.SettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ========================================== -->
        <!-- PROFILE: GOALS & TARGETS -->
        <!-- ========================================== -->
        <activity
            android:name=".features.profile.GoalsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ========================================== -->
        <!-- PROFILE: EDIT TARGETS -->
        <!-- ========================================== -->
        <activity
            android:name=".features.profile.EditTargetsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ========================================== -->
        <!-- PROFILE: CONNECTED DEVICES -->
        <!-- ========================================== -->
        <activity
            android:name=".features.profile.ConnectedDevicesActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ========================================== -->
        <!-- PROFILE: PERSONAL BASELINE -->
        <!-- ========================================== -->
        <activity
            android:name=".features.profile.PersonalBaselineActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========================================== -->
        <!-- PROFILE: SUPPORT & FEEDBACK -->
        <!-- ========================================== -->
        <activity
            android:name=".features.profile.SupportFeedbackActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Wearable Data Listener Service -->
        <service
            android:name=".services.WearableDataListenerService"
            android:exported="true"
            android:stopWithTask="false">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data android:scheme="wear" android:host="*" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*"
                    android:pathPrefix="/fitguard/activity" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*"
                    android:pathPrefix="/fitguard/device" />
            </intent-filter>
        </service>

        <!-- Mobile Foreground Service for activity data sync -->
        <service
            android:name=".services.SessionForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync|location" />

        <!-- Fatigue Alert Dismiss Receiver -->
        <receiver
            android:name=".features.fatigue.FatigueAlertManager$DismissReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.fitguard.FATIGUE_ALERT_DISMISS_PHONE" />
            </intent-filter>
        </receiver>

    </application>

</manifest>